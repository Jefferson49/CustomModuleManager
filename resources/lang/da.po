#: src/RequestHandlers/ModuleUpgradeWizardStep.php:330
#, php-format
msgid "A backup of the current module was created in %s seconds."
msgstr "En sikkerhedskopi af det aktuelle modul blev oprettet på %s sekunder."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:335
msgid "Failed to create a backup of the current module."
msgstr "Kunne ikke oprette en sikkerhedskopi af det aktuelle modul."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:362
msgid "Error during downloading the module zip file."
msgstr "Fejl under download af modulets zip-fil."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:394
msgid "Error during unzipping the module zip file."
msgstr "Fejl under udpakning af modulets zip-fil."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:508
#, php-format
msgid ""
"The module %s was rolled back to the current version, because the update "
"created errors."
msgstr ""
"Modulet %s blev rullet tilbage til den nuværende version, fordi opdateringen "
"skabte fejl."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:511
#, php-format
msgid ""
"The installation of module %s was rolled back, because the module created "
"errors."
msgstr ""
"Installationen af ​​modul %s blev rullet tilbage, fordi modulet oprettede fejl."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:521
#, php-format
msgid "A roll back of the module %s to the current version failed."
msgstr "En tilbagerulning af modulet %s til den aktuelle version mislykkedes."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:523
#, php-format
msgid ""
"Please try to manually roll back by copying the files from \"/data/tmp/backup/"
"modules_4/%s\" to \"/modules_v4/%s\"."
msgstr ""
"Prøv venligst manuelt at rulle tilbage ved at kopiere filerne fra \"/data/tmp/"
"backup/modules_4/%s\" til \"/modules_v4/%s\"."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:526
#, php-format
msgid "A roll back of the installation of module %s failed."
msgstr "En tilbagerulning af installationen af ​​modul %s mislykkedes."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:528
#, php-format
msgid ""
"Please try to manually roll back by deleting the folder \"/modules_v4/%s\""
msgstr ""
"Prøv venligst manuelt at rulle tilbage ved at slette mappen \"/modules_v4/%s\""

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:568
#, php-format
msgid "The module was successfully deleted in %s seconds."
msgstr "Modulet blev slettet på %s sekunder."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:573
msgid "Error during deleting the module."
msgstr "Fejl under sletning af modulet."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:708
msgid "continue (reload)"
msgstr "fortsæt (genindlæs)"

