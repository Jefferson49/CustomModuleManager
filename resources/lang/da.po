msgstr "Opdateringsguiden blev afbrudt"

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:220
#, php-format
msgid "Installing module \"%s\" (to folder: \"/module_v4/%s\")"
msgstr "Installation af modulet \"%s\" (til mappen: \"/module_v4/%s\")"

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:223
#, php-format
msgid "Upgrading module \"%s\" (in folder: \"/module_v4/%s\")"
msgstr "Opgraderer modul \"%s\" (i mappen: \"/module_v4/%s\")"

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:233
msgid ""
"Version % is the latest version of the custom module. No upgrade is available."
msgstr ""
"Version % er den seneste version af det brugerdefinerede modul. Der er ingen "
"opgradering tilgængelig."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:238
#, php-format
msgid ""
"This custom module can only be used with a webtrees version greater or equal "
"than %s"
msgstr ""
"Dette brugerdefinerede modul kan kun bruges med en webtrees-version, der er "
"større end eller lig med %s."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:243
msgid ""
"The PHP extension \"zip\" is not installed. In order to use the custom module, "
"your PHP installation needs to include the \"zip\" extension. You have to "
"activate the extension in your \"php.ini\" file."
msgstr ""
"PHP-udvidelsen \"zip\" er ikke installeret. For at bruge det brugerdefinerede "
"modul skal din PHP-installation inkludere udvidelsen \"zip\". Du skal aktivere "
"udvidelsen i din \"php.ini\"-fil."

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:252
msgid "Latest version"
msgstr "Seneste version"

#: src/RequestHandlers/ModuleUpgradeWizardStep.php:252
#: src/RequestHandlers/ModuleUpgradeWizardStep.php:255
#, php-format
